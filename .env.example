# ==========================================
# Variables de Entorno - Forgy Backend API
# ==========================================

# Puerto en el que correrá el servidor local
PORT=3000

# URL de la base de datos (Ejemplo para entorno local con Docker Compose)
DATABASE_URL="postgresql://forgy_user:forgy_password@localhost:5432/forgy_db?schema=public"

# Clave secreta para firmar los tokens JWT (Cámbiala en producción)
JWT_SECRET="super-secret-key-para-desarrollo-local"

# URL del Frontend para habilitar los permisos de CORS
FRONTEND_URL="http://localhost:5173"